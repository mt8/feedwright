{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "feedwright/when",
	"version": "0.1.0",
	"title": "When (conditional)",
	"category": "feedwright",
	"icon": "filter",
	"description": "Render the inner blocks only when a binding expression resolves non-empty (or empty under negate).",
	"keywords": [ "when", "if", "conditional", "filter" ],
	"textdomain": "feedwright",
	"ancestor": [ "feedwright/rss" ],
	"supports": {
		"html": false,
		"reusable": false,
		"multiple": true
	},
	"attributes": {
		"label": { "type": "string", "default": "" },
		"expression": { "type": "string", "default": "" },
		"negate": { "type": "boolean", "default": false }
	},
	"usesContext": [ "feedwright/inItemContext" ],
	"editorScript": "file:./index.js"
}
