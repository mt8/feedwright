    "mappings": {
        "wp-content/debug.log": "./debug.log",
        "db.sql": "./db.sql"
    },
    "env": {
        "tests": {
            "phpVersion": "8.3",
            "config": {
                "WP_DEBUG": true,
                "WP_DEBUG_LOG": true
            }
        }
    }
}
