{
    "core": null,
    "plugins": [
        "."
    ],
    "phpVersion": "8.3",
    "config": {
        "WP_DEBUG": true,
        "WP_DEBUG_LOG": true,
        "WP_DEBUG_DISPLAY": true,
        "SCRIPT_DEBUG": true,
        "SAVEQUERIES": true
